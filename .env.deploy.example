# =============================================================================
# .env.deploy — переменные для Deploy Manager
#
# Скопировать на сервер:
#   cp .env.deploy.example .env.deploy
#   nano .env.deploy
# =============================================================================

# ─── Безопасность ─────────────────────────────────────────────────────────────
# Секрет для верификации подписи GitHub webhook (HMAC-SHA256)
# Должен совпадать с полем "Secret" в настройках GitHub webhook
DEPLOY_SECRET=change_me_random_secret

# ─── Настройки деплоя ─────────────────────────────────────────────────────────
# Порт webhook-сервера (слушает на 0.0.0.0)
WEBHOOK_PORT=3010

# Абсолютный путь к корню проекта на сервере
PROJECT_DIR=/opt/my-project

# Имя проекта в Telegram-уведомлениях и именах PM2-процессов
PROJECT_NAME=myapp

# Ветки для деплоя (push в эти ветки запускает деплой, через запятую)
GIT_BRANCHES=main

# ─── Telegram-уведомления ─────────────────────────────────────────────────────
# Токен бота для управления деплоем (создать через @BotFather)
BOT_DEPLOY_MANAGER_TOKEN=

# Telegram ID администраторов через запятую
# Получить можно через @userinfobot
ADMIN_TG_IDS=

# ─── Multi-environment (опционально) ─────────────────────────────────────────
# Рабочая директория для dev-стека (git worktree)
# DEV_WORK_DIR=/opt/my-project-dev

# Docker Compose файлы для каждой среды
# PROD_COMPOSE_FILE=docker-compose.yml
# DEV_COMPOSE_FILE=docker-compose.dev.yml
